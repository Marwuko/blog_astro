---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import PostPreview from '../components/PostPreview.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import siteConfig from '../data/site-config';
import { sortItemsByDateDesc } from '../utils/data-utils';

const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
const featuredPosts = posts.filter(({ data }) => data.isFeatured);
const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const featuredProjects = projects.filter(({ data }) => data.isFeatured);

const stats = [
    { value: String(projects.length).padStart(2, '0'), label: 'Projects shipped' },
    { value: String(posts.length).padStart(2, '0'), label: 'Articles written' },
    { value: '06', label: 'Core skill areas' },
    { value: '02', label: 'Continents worked across' }
];

const skills = [
    {
        area: 'AI & Machine Learning',
        stack: 'Python · PyTorch · HuggingFace · RAG · LLMs · Transformers',
        icon: 'M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 3 3v1a3 3 0 0 1 1 5.24V17a3 3 0 0 1-3 3h-1a4 4 0 0 1-8 0H8a3 3 0 0 1-3-3v-.76A3 3 0 0 1 6 11v-1a3 3 0 0 1 3-3h-1V6a4 4 0 0 1 4-4Z'
    },
    {
        area: 'Data & Analytics',
        stack: 'SQL · Power BI · Tableau · pandas · Excel · R',
        icon: 'M3 3v18h18M8 17V9m5 8V5m5 12v-6'
    },
    {
        area: 'Cloud Platforms',
        stack: 'AWS · Google Cloud · Automated Pipelines',
        icon: 'M6.5 19a4.5 4.5 0 1 1 .42-8.98 6 6 0 0 1 11.58 1.6A3.5 3.5 0 0 1 17.5 19h-11Z'
    },
    {
        area: 'Databases',
        stack: 'MySQL · SQL Server · Schema Design · ER Diagrams',
        icon: 'M12 3c4.42 0 8 1.34 8 3s-3.58 3-8 3-8-1.34-8-3 3.58-3 8-3Zm8 3v12c0 1.66-3.58 3-8 3s-8-1.34-8-3V6m16 6c0 1.66-3.58 3-8 3s-8-1.34-8-3'
    },
    {
        area: 'Web Development',
        stack: 'TypeScript · Astro · React · Node.js · Tailwind CSS',
        icon: 'm8 8-4 4 4 4m8-8 4 4-4 4m-2.5-10-3 12'
    },
    {
        area: 'Systems & Automation',
        stack: 'Data Pipelines · API Integration · Workflow Automation',
        icon: 'M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm7.4 3a7.4 7.4 0 0 0-.1-1.2l2-1.6-2-3.4-2.4 1a7.5 7.5 0 0 0-2-1.2L14.5 3h-5l-.4 2.6a7.5 7.5 0 0 0-2 1.2l-2.4-1-2 3.4 2 1.6a7.4 7.4 0 0 0 0 2.4l-2 1.6 2 3.4 2.4-1a7.5 7.5 0 0 0 2 1.2l.4 2.6h5l.4-2.6a7.5 7.5 0 0 0 2-1.2l2.4 1 2-3.4-2-1.6c.07-.4.1-.8.1-1.2Z'
    }
];
---

<BaseLayout title={siteConfig.title} description={siteConfig.description} image={siteConfig.image} showHeader={false}>
    <Hero />

    <!-- Stats band -->
    <section class="mb-20 sm:mb-28" data-reveal>
        <div class="holo-card rounded-2xl grid grid-cols-2 lg:grid-cols-4 divide-x divide-y lg:divide-y-0 divide-main/10 overflow-hidden">
            {stats.map((stat) => (
                <div class="p-6 text-center">
                    <p class="font-display text-3xl sm:text-4xl font-semibold text-gradient">{stat.value}</p>
                    <p class="mt-1.5 text-[10px] font-mono uppercase tracking-[0.16em] text-main/50">{stat.label}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- About teaser -->
    <section class="mb-20 sm:mb-28" data-reveal>
        <p class="text-[11px] font-mono uppercase tracking-[0.2em] font-semibold text-accent mb-3">01 / About</p>
        <p class="max-w-2xl text-base sm:text-lg text-main/65 leading-relaxed">
            I'm <strong class="text-main font-semibold">Felix Marwuko</strong>, an IT and data professional based in South Korea.
            I hold a <strong class="text-main font-semibold">B.S. in Information Technology (Data Science)</strong> from
            <strong class="text-main font-semibold">UMass Global</strong> and serve as a
            <strong class="text-main font-semibold">Teaching Assistant at Woosong University</strong>.
            I build at the intersection of <strong class="text-main font-semibold">AI, databases, and automation</strong>.
        </p>
        <div class="mt-7">
            <Button href="/about">More About Me</Button>
        </div>
    </section>

    <!-- Skills grid -->
    <section class="mb-20 sm:mb-28">
        <div data-reveal>
            <p class="text-[11px] font-mono uppercase tracking-[0.2em] font-semibold text-accent mb-3">02 / Expertise</p>
            <h2 class="text-2xl font-display font-semibold tracking-tight mb-8 sm:text-3xl">Skills & Stack</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {skills.map((skill, i) => (
                <div class="holo-card p-5 rounded-xl" data-reveal style={`--reveal-delay: ${(i % 3) * 80}ms`}>
                    <div class="w-9 h-9 mb-4 rounded-lg bg-accent/10 border border-accent/25 grid place-items-center text-accent">
                        <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <path d={skill.icon} />
                        </svg>
                    </div>
                    <h3 class="text-sm font-display font-semibold mb-2">{skill.area}</h3>
                    <p class="text-xs font-mono text-main/50 leading-relaxed">{skill.stack}</p>
                </div>
            ))}
        </div>
    </section>

    {featuredProjects?.length > 0 && (
        <section class="mb-20 sm:mb-28">
            <div data-reveal>
                <p class="text-[11px] font-mono uppercase tracking-[0.2em] font-semibold text-accent mb-3">03 / Selected Work</p>
                <h2 class="text-2xl font-display font-semibold tracking-tight mb-8 sm:text-3xl">Featured Projects</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {featuredProjects.map((project, i) => (
                    <div data-reveal style={`--reveal-delay: ${(i % 2) * 90}ms`}>
                        <ProjectPreview project={project} headingLevel="h3" index={i} />
                    </div>
                ))}
            </div>
            <div class="mt-10" data-reveal>
                <Button href="/projects">View All Projects</Button>
            </div>
        </section>
    )}

    {featuredPosts?.length > 0 && (
        <section class="mb-20 sm:mb-28">
            <div data-reveal>
                <p class="text-[11px] font-mono uppercase tracking-[0.2em] font-semibold text-accent mb-3">04 / Writing</p>
                <h2 class="text-2xl font-display font-semibold tracking-tight mb-6 sm:text-3xl">Latest Articles</h2>
            </div>
            <div data-reveal>
                {featuredPosts.map((post) => (
                    <PostPreview post={post} headingLevel="h3" />
                ))}
            </div>
            <div class="mt-10" data-reveal>
                <Button href="/blog">View All Posts</Button>
            </div>
        </section>
    )}

    <!-- Closing CTA -->
    <section class="mb-20 sm:mb-28" data-reveal>
        <div class="holo-card relative rounded-2xl px-8 py-14 sm:px-14 sm:py-16 text-center overflow-hidden">
            <div class="pointer-events-none absolute -top-24 left-1/2 -translate-x-1/2 w-96 h-48 bg-accent/20 blur-3xl rounded-full" aria-hidden="true"></div>
            <p class="text-[11px] font-mono uppercase tracking-[0.2em] font-semibold text-accent mb-4">05 / Contact</p>
            <h2 class="text-3xl sm:text-4xl font-display font-semibold tracking-tight max-w-xl mx-auto">
                Let's build <span class="text-gradient">what's next</span> together.
            </h2>
            <p class="mt-4 max-w-md mx-auto text-sm sm:text-base text-main/60 leading-relaxed">
                Have a project in mind, or want to talk AI, data, and systems? I'm always open to interesting conversations and opportunities.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-3">
                <Button href="/contact" variant="primary">Get in Touch <span aria-hidden="true">→</span></Button>
                <Button href="/projects">Explore My Work</Button>
            </div>
        </div>
    </section>
</BaseLayout>
