---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import PostPreview from '../components/PostPreview.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import siteConfig from '../data/site-config';
import { sortItemsByDateDesc } from '../utils/data-utils';

const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
const featuredPosts = posts.filter(({ data }) => data.isFeatured);
const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const featuredProjects = projects.filter(({ data }) => data.isFeatured);

const skills = [
    { area: 'AI & Machine Learning', stack: 'Python · PyTorch · HuggingFace · RAG · LLMs · Transformers' },
    { area: 'Data & Analytics', stack: 'SQL · Power BI · Tableau · pandas · Excel · R' },
    { area: 'Cloud Platforms', stack: 'AWS · Google Cloud · Automated Pipelines' },
    { area: 'Databases', stack: 'MySQL · SQL Server · Schema Design · ER Diagrams' },
    { area: 'Web Development', stack: 'TypeScript · Astro · React · Node.js · Tailwind CSS' },
    { area: 'Systems & Automation', stack: 'Data Pipelines · API Integration · Workflow Automation' },
];
---

<BaseLayout title={siteConfig.title} description={siteConfig.description} image={siteConfig.image} showHeader={false}>
    <Hero />

    <!-- About teaser -->
    <section class="mb-20 sm:mb-28">
        <p class="text-[11px] uppercase tracking-[0.2em] font-semibold text-accent mb-3">About</p>
        <p class="max-w-2xl text-base sm:text-lg text-main/65 leading-relaxed">
            I'm <strong class="text-main font-semibold">Felix Marwuko</strong>, an IT and data professional based in South Korea.
            I hold a <strong class="text-main font-semibold">B.S. in Information Technology (Data Science)</strong> from
            <strong class="text-main font-semibold">UMass Global</strong> and serve as a
            <strong class="text-main font-semibold">Teaching Assistant at Woosong University</strong>.
            I build at the intersection of <strong class="text-main font-semibold">AI, databases, and automation</strong>.
        </p>
        <div class="mt-7">
            <Button href="/about">More About Me</Button>
        </div>
    </section>

    <!-- Skills grid -->
    <section class="mb-20 sm:mb-28">
        <p class="text-[11px] uppercase tracking-[0.2em] font-semibold text-accent mb-3">Expertise</p>
        <h2 class="text-2xl font-serif font-medium tracking-tight mb-8 sm:text-3xl">Skills & Stack</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {skills.map((skill) => (
                <div class="p-5 rounded-xl border border-main/10 bg-surface">
                    <h3 class="text-sm font-semibold text-accent mb-2">{skill.area}</h3>
                    <p class="text-xs text-main/50 leading-relaxed">{skill.stack}</p>
                </div>
            ))}
        </div>
    </section>

    {featuredProjects?.length > 0 && (
        <section class="mb-20 sm:mb-28">
            <p class="text-[11px] uppercase tracking-[0.2em] font-semibold text-accent mb-3">Selected Work</p>
            <h2 class="text-2xl font-serif font-medium tracking-tight mb-8 sm:text-3xl">Featured Projects</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {featuredProjects.map((project) => (
                    <ProjectPreview project={project} headingLevel="h3" />
                ))}
            </div>
            <div class="mt-10">
                <Button href="/projects">View All Projects</Button>
            </div>
        </section>
    )}

    {featuredPosts?.length > 0 && (
        <section class="mb-20 sm:mb-28">
            <p class="text-[11px] uppercase tracking-[0.2em] font-semibold text-accent mb-3">Writing</p>
            <h2 class="text-2xl font-serif font-medium tracking-tight mb-6 sm:text-3xl">Latest Articles</h2>
            <div>
                {featuredPosts.map((post) => (
                    <PostPreview post={post} headingLevel="h3" />
                ))}
            </div>
            <div class="mt-10">
                <Button href="/blog">View All Posts</Button>
            </div>
        </section>
    )}
</BaseLayout>
