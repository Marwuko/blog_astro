---
import siteConfig from '../data/site-config';

const navLinks = siteConfig.footerNavLinks || [
    { text: 'About', href: '/about' },
    { text: 'Contact', href: '/contact' },
    { text: 'Terms', href: '/terms' }
];

const socialLinks = siteConfig.socialLinks || [];
---

<footer class="relative w-full mt-12 border-t border-main/10">
    <div class="w-full max-w-4xl mx-auto px-4 md:px-8 pt-12 pb-10 sm:pt-16 sm:pb-14">
        <div class="grid gap-8 sm:grid-cols-[1fr_auto]">
            <!-- Brand identity -->
            <div>
                <a href="/" class="group inline-flex items-center gap-3">
                    <span class="w-8 h-8 rounded-lg border-2 border-main/70 grid place-items-center font-mono text-[10px] font-semibold transition-colors duration-200 group-hover:border-accent group-hover:text-accent">
                        FM
                    </span>
                    <span class="font-display text-xl font-semibold tracking-tight transition-colors duration-200 group-hover:text-accent">
                        Felix Marwuko
                    </span>
                </a>
                {siteConfig.subtitle && (
                    <p class="mt-2.5 text-[11px] font-mono uppercase tracking-[0.18em] text-main/45">
                        {siteConfig.subtitle}
                    </p>
                )}
            </div>

            <!-- Nav + live product links -->
            <div class="flex flex-wrap gap-x-10 gap-y-6 items-start sm:text-right">
                <div>
                    <p class="text-[10px] font-mono uppercase tracking-[0.16em] text-main/40 mb-2.5">Pages</p>
                    <div class="flex flex-wrap sm:flex-col gap-x-6 gap-y-1.5">
                        {navLinks.map((link) => (
                            <a class="text-sm font-medium transition-colors duration-200 hover:text-accent" href={link.href}>
                                {link.text}
                            </a>
                        ))}
                    </div>
                </div>
                <div>
                    <p class="text-[10px] font-mono uppercase tracking-[0.16em] text-main/40 mb-2.5">Live Products</p>
                    <div class="flex flex-wrap sm:flex-col gap-x-6 gap-y-1.5">
                        <a
                            class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200 hover:text-accent sm:justify-end"
                            href="https://www.flexaipos.com"
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                            FlexAI POS
                        </a>
                        <a
                            class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200 hover:text-accent sm:justify-end"
                            href="https://technabi.com"
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                            Technabi
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="mt-10 pt-6 border-t border-main/10 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex flex-wrap gap-x-5 gap-y-1">
                {socialLinks.map((link) => (
                    <a
                        class="text-sm text-main/55 transition-colors duration-200 hover:text-accent"
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {link.text}
                    </a>
                ))}
            </div>
            <p class="text-xs font-mono text-main/35">
                &copy; {new Date().getFullYear()} Felix Marwuko · Crafted with Astro
            </p>
        </div>
    </div>
</footer>
