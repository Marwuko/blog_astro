---
import siteConfig from '../data/site-config';

const navLinks = siteConfig.footerNavLinks || [
    { text: 'About', href: '/about' },
    { text: 'Contact', href: '/contact' },
    { text: 'Terms', href: '/terms' }
];

const socialLinks = siteConfig.socialLinks || [];

const liveProducts = [
    { text: 'FlexAI POS', href: 'https://www.flexaipos.com' },
    { text: 'Technabi', href: 'https://technabi.com' }
];

const year = new Date().getFullYear();
---

<footer class="relative w-full mt-16 border-t border-main/10">
    <div class="w-full max-w-4xl mx-auto px-4 md:px-8 pt-14 pb-10 sm:pt-16 sm:pb-12">
        <div class="grid grid-cols-2 gap-x-8 gap-y-12 sm:grid-cols-[1.6fr_1fr_1fr_1fr]">
            <!-- Brand -->
            <div class="col-span-2 sm:col-span-1">
                <a href="/" class="group inline-flex items-center gap-3">
                    <span class="w-9 h-9 rounded-lg border-2 border-main/70 grid place-items-center font-mono text-[11px] font-semibold transition-colors duration-200 group-hover:border-accent group-hover:text-accent">
                        FM
                    </span>
                    <span class="font-display text-xl font-semibold tracking-tight transition-colors duration-200 group-hover:text-accent">
                        Felix Marwuko
                    </span>
                </a>
                <p class="mt-4 max-w-xs text-sm leading-relaxed text-main/50">
                    IT and data professional building at the intersection of AI, databases, and automation.
                </p>
                {siteConfig.subtitle && (
                    <p class="mt-4 text-[11px] font-mono uppercase tracking-[0.18em] text-main/40">
                        {siteConfig.subtitle}
                    </p>
                )}
            </div>

            <!-- Pages -->
            <nav aria-label="Footer pages">
                <p class="text-[10px] font-mono uppercase tracking-[0.18em] text-main/40 mb-4">Pages</p>
                <ul class="space-y-3">
                    {navLinks.map((link) => (
                        <li>
                            <a class="text-sm text-main/70 transition-colors duration-200 hover:text-accent" href={link.href}>
                                {link.text}
                            </a>
                        </li>
                    ))}
                </ul>
            </nav>

            <!-- Live Products -->
            <nav aria-label="Live products">
                <p class="text-[10px] font-mono uppercase tracking-[0.18em] text-main/40 mb-4">Live Products</p>
                <ul class="space-y-3">
                    {liveProducts.map((product) => (
                        <li>
                            <a
                                class="group inline-flex items-center gap-2 text-sm text-main/70 transition-colors duration-200 hover:text-accent"
                                href={product.href}
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block shrink-0"></span>
                                {product.text}
                            </a>
                        </li>
                    ))}
                </ul>
            </nav>

            <!-- Connect -->
            {socialLinks.length > 0 && (
                <nav aria-label="Social links">
                    <p class="text-[10px] font-mono uppercase tracking-[0.18em] text-main/40 mb-4">Connect</p>
                    <ul class="space-y-3">
                        {socialLinks.map((link) => (
                            <li>
                                <a
                                    class="text-sm text-main/70 transition-colors duration-200 hover:text-accent"
                                    href={link.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    {link.text}
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            )}
        </div>

        <!-- Bottom bar -->
        <div class="mt-14 pt-6 border-t border-main/10 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-xs font-mono text-main/40">
                &copy; {year} Felix Marwuko. All rights reserved.
            </p>
            <p class="text-xs font-mono text-main/30">
                Designed &amp; built with Astro
            </p>
        </div>
    </div>
</footer>
