---
import type { HTMLAttributes } from 'astro/types';

type AnchorProps = HTMLAttributes<'a'> & { type?: never; variant?: 'primary' | 'ghost' };
type ButtonProps = HTMLAttributes<'button'> & { href?: never; variant?: 'primary' | 'ghost' };
type Props = ButtonProps | AnchorProps;

const { href, class: className, variant = 'ghost', ...rest } = Astro.props;

const base =
    'inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold tracking-wide rounded-lg transition-all duration-300 gap-2';
const variants: Record<string, string> = {
    primary: 'bg-accent text-white dark:text-black/85 border border-accent hover:opacity-90 hover:-translate-y-px active:translate-y-0',
    ghost: 'glass-panel text-main hover:border-accent/60 hover:text-accent hover:bg-accent/5 hover:-translate-y-px active:translate-y-0'
};
const cls = `${base} ${variants[variant as string] ?? variants.ghost}`;
---

{href ? (
    <a href={href} class:list={[cls, className]} {...rest}><slot /></a>
) : (
    <button class:list={[cls, className]} {...rest}><slot /></button>
)}
