---
import { marked } from 'marked';
import Button from './Button.astro';
import siteConfig from '../data/site-config';

const hero = siteConfig.hero;
const subtitle = siteConfig.subtitle;
---

{(hero?.title || hero?.text || (hero?.actions && hero.actions.length > 0)) && (
    <section class="relative w-full mb-24 sm:mb-32 pt-8 pb-8">
        <!-- Ambient glow -->
        <div class="pointer-events-none absolute -top-20 -left-20 w-96 h-96 bg-accent/8 rounded-full blur-3xl"></div>
        <div class="pointer-events-none absolute top-40 right-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl"></div>

        <!-- Badge -->
        {subtitle && (
            <div class="mb-8">
                <span class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] font-semibold text-accent border border-accent/30 bg-accent/8 px-4 py-2 rounded-full">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block"></span>
                    {subtitle}
                </span>
            </div>
        )}

        <div class="grid gap-14 items-center lg:grid-cols-[1.15fr_0.85fr]">
            <!-- LEFT: text -->
            <div class="space-y-8">
                {hero.title && (
                    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-serif font-medium tracking-tight leading-[1.05]">
                        {hero.title}
                    </h1>
                )}

                {hero.text && (
                    <div class="max-w-xl text-base sm:text-lg text-main/65 leading-relaxed prose prose-dante"
                        set:html={marked.parse(hero.text)}
                    />
                )}

                {hero.actions && hero.actions.length > 0 && (
                    <div class="flex flex-wrap gap-3 pt-1">
                        {hero.actions.map((action, i) => (
                            <Button href={action.href} variant={i === 0 ? 'primary' : 'ghost'}>
                                {action.text}
                            </Button>
                        ))}
                    </div>
                )}

                <!-- Trust indicators -->
                <div class="flex flex-wrap gap-x-6 gap-y-2 pt-2 text-xs text-main/35 font-medium uppercase tracking-widest">
                    <span>B.S. Information Technology</span>
                    <span>·</span>
                    <span>AWS AI Scientist</span>
                    <span>·</span>
                    <span>Woosong University TA</span>
                </div>
            </div>

            <!-- RIGHT: image with glow frame -->
            {hero.image?.src && (
                <figure class="relative mt-4 lg:mt-0">
                    <div class="absolute -inset-px bg-gradient-to-br from-accent/30 via-accent/10 to-transparent rounded-2xl blur-sm"></div>
                    <div class="relative overflow-hidden rounded-2xl border border-accent/20 bg-surface">
                        <img
                            class="w-full h-full object-cover"
                            src={hero.image.src}
                            loading="eager"
                            decoding="async"
                            alt={hero.image.alt || ''}
                        />
                    </div>
                </figure>
            )}
        </div>
    </section>
)}
