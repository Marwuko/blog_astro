---
import { marked } from 'marked';
import Button from './Button.astro';
import siteConfig from '../data/site-config';

const hero = siteConfig.hero;
const subtitle = siteConfig.subtitle;

// A '|' in the hero title marks where the gradient-highlighted part begins
const [titlePlain, titleGradient] = (hero?.title || '').split('|');

const credentials = ['B.S. Information Technology', 'AWS AI Scientist', 'Woosong University TA'];
---

{(hero?.title || hero?.text || (hero?.actions && hero.actions.length > 0)) && (
    <section class="relative w-full mb-24 sm:mb-32 pt-10 pb-8">
        <!-- Status + domain badges -->
        <div class="flex flex-wrap items-center gap-3 mb-8" data-reveal>
            <span class="inline-flex items-center gap-2.5 text-[11px] font-mono uppercase tracking-[0.18em] font-medium glass-panel text-main/80 px-4 py-2 rounded-full">
                <span class="pulse-dot w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span>
                Open to opportunities
            </span>
            {subtitle && (
                <span class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[0.18em] font-medium text-accent border border-accent/30 bg-accent/10 px-4 py-2 rounded-full">
                    {subtitle}
                </span>
            )}
        </div>

        <div class="grid gap-14 items-center lg:grid-cols-[1.15fr_0.85fr]">
            <!-- LEFT: text -->
            <div class="space-y-8">
                {hero.title && (
                    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-display font-semibold tracking-tight leading-[1.04]" data-reveal>
                        {titlePlain}
                        {titleGradient && (
                            <>
                                <br />
                                <span class="text-gradient">{titleGradient}</span>
                            </>
                        )}
                    </h1>
                )}

                {hero.text && (
                    <div
                        class="max-w-xl text-base sm:text-lg text-main/65 leading-relaxed prose prose-dante"
                        data-reveal
                        style="--reveal-delay: 100ms"
                        set:html={marked.parse(hero.text)}
                    />
                )}

                {hero.actions && hero.actions.length > 0 && (
                    <div class="flex flex-wrap gap-3 pt-1" data-reveal style="--reveal-delay: 180ms">
                        {hero.actions.map((action, i) => (
                            <Button href={action.href} variant={i === 0 ? 'primary' : 'ghost'}>
                                {action.text}
                                {i === 0 && <span aria-hidden="true">→</span>}
                            </Button>
                        ))}
                    </div>
                )}

                <!-- Credentials -->
                <div class="flex flex-wrap gap-2 pt-2" data-reveal style="--reveal-delay: 260ms">
                    {credentials.map((item) => (
                        <span class="text-[10px] font-mono uppercase tracking-[0.14em] text-main/50 border border-main/15 rounded-md px-3 py-1.5">
                            {item}
                        </span>
                    ))}
                </div>
            </div>

            <!-- RIGHT: image with gradient frame -->
            {hero.image?.src && (
                <figure class="relative mt-4 lg:mt-0" data-reveal style="--reveal-delay: 150ms">
                    <div class="absolute -inset-1 bg-gradient-to-br from-accent/50 via-accent-2/25 to-transparent rounded-3xl blur-md opacity-70"></div>
                    <div class="relative overflow-hidden rounded-2xl border border-accent/25 bg-surface shadow-glow">
                        <img
                            class="w-full h-full object-cover"
                            src={hero.image.src}
                            loading="eager"
                            decoding="async"
                            alt={hero.image.alt || ''}
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-main/40 via-transparent to-transparent"></div>
                    </div>
                    <!-- Floating chip -->
                    <div class="absolute -bottom-4 -left-4 glass-panel rounded-xl px-4 py-3 shadow-lg">
                        <p class="text-[10px] font-mono uppercase tracking-[0.16em] text-main/50">Based in</p>
                        <p class="text-sm font-display font-semibold">South Korea 🇰🇷</p>
                    </div>
                </figure>
            )}
        </div>
    </section>
)}
