---
import { type CollectionEntry } from 'astro:content';
import ArrowRight from '../icons/ArrowRight.astro';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };
const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description } = project.data;
const TitleTag = headingLevel;
---

<a
    class:list={[
        'group relative block p-6 rounded-xl border border-main/10 bg-surface transition-all duration-300',
        'hover:border-accent/35 hover:bg-surface',
        className
    ]}
    href={`/projects/${project.slug}/`}
>
    <!-- Top row: title + arrow -->
    <div class="flex items-start justify-between gap-4 mb-3">
        <TitleTag class="text-lg font-serif font-medium tracking-tight leading-snug transition-colors duration-200 group-hover:text-accent sm:text-xl">
            {title}
        </TitleTag>
        <div class="shrink-0 mt-0.5 w-7 h-7 rounded-full border border-main/15 flex items-center justify-center opacity-0 group-hover:opacity-100 group-hover:border-accent/50 transition-all duration-200">
            <ArrowRight class="fill-current w-3 h-3 text-accent" />
        </div>
    </div>

    {description && (
        <p class="text-sm leading-relaxed text-main/50 line-clamp-2">{description}</p>
    )}

    <!-- Bottom accent line on hover -->
    <div class="absolute bottom-0 left-6 right-6 h-px bg-accent/0 group-hover:bg-accent/30 transition-all duration-300 rounded-full"></div>
</a>
