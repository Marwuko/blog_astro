---
import Button from './Button.astro';
import siteConfig from '../data/site-config';

const subscribe = siteConfig.subscribe;

const { class: className } = Astro.props;
---

{
    subscribe?.formUrl && (
        <section class:list={['spot-card rounded-2xl px-8 py-12 flex flex-col items-center text-center overflow-hidden sm:px-12 sm:py-16', className]}>
            <p class="text-[11px] font-mono uppercase tracking-[0.2em] font-semibold text-accent mb-3">Newsletter</p>
            {subscribe.title && (
                <h2 class:list={['w-full max-w-xl text-2xl leading-tight font-display font-semibold tracking-tight sm:text-3xl', subscribe.text ? 'mb-4' : 'mb-8']}>
                    {subscribe.title}
                </h2>
            )}
            {subscribe.text && <p class="w-full max-w-xl mb-8 text-sm leading-relaxed text-main/60">{subscribe.text}</p>}
            <form
                action={subscribe.formUrl}
                method="post"
                id="subscribe-form"
                name="subscribe-form"
                class="w-full max-w-xl flex flex-col gap-3.5 sm:flex-row"
                target="_blank"
            >
                <label for="email" class="sr-only">
                    Email Address
                </label>
                <input
                    type="email"
                    name="email"
                    id="email"
                    class="w-full h-11 px-5 text-sm text-main bg-main/40 border border-main/20 rounded-lg placeholder:text-main/40 focus:outline-none focus:border-accent/60 transition-colors duration-200"
                    required=""
                    value=""
                    placeholder="you@example.com"
                />
                <Button type="submit" name="subscribe" variant="primary" class="w-full h-11 sm:w-auto shrink-0">
                    Subscribe
                </Button>
            </form>
        </section>
    )
}
